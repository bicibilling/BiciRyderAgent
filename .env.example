# =============================================================================
# BICI RYDER AI AGENT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your actual API keys and values
# Never commit .env files to version control!

# =============================================================================
# ELEVENLABS CONFIGURATION
# =============================================================================
# Get your API key from: https://elevenlabs.io/app/settings
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Agent ID (will be populated after creating Ryder agent)
ELEVENLABS_AGENT_ID=your_agent_id_here
# Phone number ID from ElevenLabs (for telephony)
ELEVENLABS_PHONE_NUMBER_ID=your_phone_number_id_here
# Webhook secret for securing incoming webhooks
ELEVENLABS_WEBHOOK_SECRET=your_webhook_secret_here
# Your domain for webhook URLs
ELEVENLABS_WEBHOOK_URL=https://yourdomain.com/api/webhooks/elevenlabs

# =============================================================================
# TWILIO CONFIGURATION
# =============================================================================
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Your Twilio phone number for SMS and calls
TWILIO_PHONE_NUMBER=+1234567890
# Webhook URL for Twilio callbacks
TWILIO_WEBHOOK_URL=https://yourdomain.com/api/webhooks/twilio

# =============================================================================
# SUPABASE CONFIGURATION  
# =============================================================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# =============================================================================
# HUBSPOT CRM INTEGRATION
# =============================================================================
# Get from HubSpot developer portal
HUBSPOT_API_KEY=your_hubspot_api_key_here
HUBSPOT_PORTAL_ID=your_hubspot_portal_id_here

# =============================================================================
# GOOGLE INTEGRATION (for store hours)
# =============================================================================
# Google My Business API key for real-time store hours
GOOGLE_MY_BUSINESS_API_KEY=your_google_api_key_here
# Google Place ID for Bici store
GOOGLE_PLACE_ID=your_bici_google_place_id_here

# =============================================================================
# STORE CONFIGURATION
# =============================================================================
# Store timezone for accurate date/time calculations
STORE_TIMEZONE=America/Vancouver
# Store location details
STORE_NAME=Bici
STORE_ADDRESS=1497 Adanac Street, Vancouver, BC, Canada
STORE_PHONE=+17787193080
STORE_EMAIL=hello@bici.cc
STORE_WEBSITE=https://www.bici.cc

# Store hours (JSON format for complex scheduling)
STORE_HOURS={"monday":{"open":"08:00","close":"18:00"},"tuesday":{"open":"08:00","close":"18:00"},"wednesday":{"open":"08:00","close":"18:00"},"thursday":{"open":"08:00","close":"18:00"},"friday":{"open":"08:00","close":"18:00"},"saturday":{"open":"09:00","close":"16:30"},"sunday":{"open":"09:00","close":"16:30"}}

# =============================================================================
# HUMAN AGENT CONFIGURATION
# =============================================================================
# Webhook URL for human agent notifications
HUMAN_AGENT_WEBHOOK_URL=https://yourdomain.com/api/human-control/notify
# Timeout for agent response (milliseconds)
AGENT_NOTIFICATION_TIMEOUT=30000
# Maximum wait time for human transfer (milliseconds)
HUMAN_TRANSFER_MAX_WAIT=180000

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application port
PORT=3001
# Environment (development, staging, production)
NODE_ENV=development
# Domain for CORS and webhooks
DOMAIN=yourdomain.com
# Security
JWT_SECRET=your_jwt_secret_for_session_management

# =============================================================================
# AGENT TESTING & MONITORING
# =============================================================================
# Phone number for testing agent functionality
AGENT_TEST_PHONE_NUMBER=+1234567890
# Webhook for performance analytics
AGENT_PERFORMANCE_WEBHOOK=https://yourdomain.com/api/analytics/agent-performance
# Enable verbose logging for debugging
DEBUG_MODE=true

# =============================================================================
# QUEBEC FRENCH LANGUAGE DETECTION
# =============================================================================
# Quebec area codes for automatic French language switching
QUEBEC_AREA_CODES=418,438,450,514,579,581,819,873

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================
# Slack webhook for team notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
# Email service for notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password