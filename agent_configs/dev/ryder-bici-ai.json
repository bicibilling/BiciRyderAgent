{
    "name": "Ryder - Bici AI Teammate",
    "conversation_config": {
        "agent": {
            "prompt": {
                "prompt": "TEST PRESERVE VOICE AND FIRST MESSAGE",
                "llm": "gemini-2.0-flash",
                "temperature": 0.2,
                "max_tokens": 500
            },
            "language": "en",
            "first_message": "Hi! I'm Ryder, your AI teammate at Bici. I can help with store hours, our location, or connecting you with the right department. If you'd like to talk to a person, just say 'human' and I'll connect you. How can I help you today?"
        },
        "conversation": {
            "text_only": false,
            "max_duration_seconds": 3600,
            "client_events": [
                "audio",
                "interruption"
            ],
            "inactivity_timeout_seconds": 300
        },
        "tts": {
            "model_id": "eleven_turbo_v2",
            "voice_id": "pNInz6obpgDQGcFmaJgB",
            "stability": 0.85,
            "similarity_boost": 0.75,
            "style": 0.15,
            "use_speaker_boost": true,
            "agent_output_audio_format": "pcm_16000",
            "optimize_streaming_latency": 3
        },
        "asr": {
            "quality": "high",
            "provider": "elevenlabs",
            "user_input_audio_format": "pcm_16000"
        },
        "turn": {
            "turn_timeout": 7,
            "silence_end_call_timeout": -1,
            "mode": "turn"
        },
        "webhooks": [
            {
                "event": "conversation_initiation",
                "url": "https://bici-ryder-api.onrender.com/api/webhooks/elevenlabs/conversation-start"
            },
            {
                "event": "post_call",
                "url": "https://bici-ryder-api.onrender.com/api/webhooks/elevenlabs/post-call"
            },
            {
                "event": "conversation_interruption",
                "url": "https://bici-ryder-api.onrender.com/api/webhooks/elevenlabs/conversation-interrupt"
            }
        ],
        "tools": [
            {
                "type": "client_tool",
                "name": "transfer_to_number",
                "description": "Transfer the current call to a human agent when customer requests human assistance or escalation is needed. Use the current transfer number from dynamic variables.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "phone_number": {
                            "type": "string",
                            "description": "The phone number to transfer to (use {{transfer_phone_number}} from dynamic variables)"
                        },
                        "reason": {
                            "type": "string",
                            "description": "Brief reason for transfer (e.g., 'customer requested human agent', 'complex inquiry')"
                        },
                        "client_message": {
                            "type": "string",
                            "description": "Message to play to customer during transfer in Ryder's voice (e.g., 'Let me connect you with one of our team members right away!')"
                        }
                    },
                    "required": [
                        "phone_number",
                        "reason",
                        "client_message"
                    ]
                }
            }
        ]
    },
    "analysis": {
        "data_collection": [
            {
                "identifier": "customer_name",
                "data_type": "string",
                "description": "Extract customer's name if provided"
            },
            {
                "identifier": "bike_type",
                "data_type": "string",
                "description": "road, mountain, hybrid, e-bike, kids, or unsure"
            },
            {
                "identifier": "purchase_timeline",
                "data_type": "string",
                "description": "immediate, this_week, this_month, just_browsing, unsure"
            },
            {
                "identifier": "budget_range",
                "data_type": "string",
                "description": "under_500, 500_1000, 1000_2000, over_2000, not_specified"
            },
            {
                "identifier": "riding_experience",
                "data_type": "string",
                "description": "beginner, intermediate, advanced, returning_rider, unsure"
            },
            {
                "identifier": "customer_triggers",
                "data_type": "string",
                "description": "hours, directions, prices, appointment, test_ride, complaint, general_help"
            },
            {
                "identifier": "follow_up_needed",
                "data_type": "string",
                "description": "Determine best SMS follow-up action"
            }
        ]
    },
    "platform_settings": {
        "widget": {
            "variant": "full",
            "placement": "bottom-right",
            "bg_color": "#F8F9FA",
            "text_color": "#2C2C2C",
            "btn_color": "#2B5AA0",
            "btn_text_color": "#ffffff",
            "border_color": "#4A90A4",
            "focus_color": "#2B5AA0",
            "text_input_enabled": true,
            "transcript_enabled": true,
            "supports_text_only": true,
            "text_only": false,
            "mic_muting_enabled": true,
            "avatar": {
                "type": "orb",
                "color_1": "#2B5AA0",
                "color_2": "#4A90A4"
            }
        },
        "privacy": {
            "record_voice": true,
            "retention_days": 30
        }
    },
    "phone_numbers": [
        "phnum_8601k3aqzvzree7858ftsv7m5cdz"
    ],
    "tags": [
        "environment:dev",
        "store:bici",
        "agent:ryder"
    ]
}